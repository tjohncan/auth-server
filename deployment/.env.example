# =============================================================================
# Copy this file to .env and customize. NEVER commit .env to version control.
# =============================================================================

# Domain
DOMAIN=auth.example.com
# AFFILIATE=https://sponsor.org

# Database — "sqlite" or "postgresql"
DB_BACKEND=sqlite

# PostgreSQL (only used when DB_BACKEND=postgresql)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=auth
POSTGRES_USER=auth_service
POSTGRES_PASSWORD=

# Email support (requires EMAIL_SUPPORT=1 build flag)
# EMAIL_SUPPORT=1
# EXTRA_PACKAGES=aws-cli
# AUTH_EMAIL_COMMAND=./deployment/email/send-email.sh
# AUTH_EMAIL_FROM=noreply@example.com
# AUTH_EMAIL_FROM_NAME=Auth System
