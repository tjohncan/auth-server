#!/bin/bash
# No-op email script for testing the email delivery pipeline.
# Logs the JSON payload to a file without sending anything.
#
# WARNING: Logged payloads contain sensitive one-time tokens (password reset,
# email verification, invitation URLs). Do NOT use this script in production.

LOG_FILE="${EMAIL_LOG_FILE:-/tmp/auth-server-email.log}"

read -r payload
echo "$(date -Iseconds) $payload" >> "$LOG_FILE"
